+    private void loadReviews() {
+        lastReviewVisible = null;
+        isReviewLoading = false;
+        hasMoreReviews = true;
+        reviewAdapter.setReviews(new java.util.ArrayList<>());
+        tvLoadMoreComments.setVisibility(View.GONE);
