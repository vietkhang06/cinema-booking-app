<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer ring -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="1.5dp" android:color="#E8640C" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <!-- Inner filled dot -->
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="oval">
            <solid android:color="#E8640C" />
        </shape>
    </item>
</layer-list>
