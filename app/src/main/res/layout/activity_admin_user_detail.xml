<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFC"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Elegant Toolbar with Back Card & Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnAdminBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeColor="#ECE8F0"
            app:strokeWidth="1.5dp"
            app:cardElevation="1dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/chevron_left_solid_full"
                app:tint="#1E1A23" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Chi tiết người dùng"
            android:textColor="#1E1A23"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Profile Overview Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1.5dp"
                app:cardElevation="1dp">

                <LinearLayout
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:orientation="horizontal"
                     android:padding="16dp"
                     android:gravity="center_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardCornerRadius="32dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#F6F4F8">
                        <ImageView
                            android:id="@+id/ivDetailAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/user_solid_full"
                            app:tint="#7A757F" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDetailName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tên Người Dùng"
                            android:textColor="#1E1A23"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDetailEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="email@cinema.com"
                            android:textColor="#7A757F"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvDetailPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="SĐT: 0123456789"
                            android:textColor="#7A757F"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvDetailCinema"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Chưa phân rạp"
                            android:textColor="#7952B3"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDetailStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOẠT ĐỘNG"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#10B981"
                        android:background="@drawable/bg_status_active_pill"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:layout_gravity="top" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- User Details CardView -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUserDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1.5dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin chi tiết tài khoản"
                        android:textColor="#1E1A23"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvUserEmailDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email: N/A"
                        android:textColor="#7A757F"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvUserRoleDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vai trò: N/A"
                        android:textColor="#7A757F"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvUserCreatedDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngày tạo tài khoản: N/A"
                        android:textColor="#7A757F"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvUserLoginCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số lần đăng nhập: 0"
                        android:textColor="#7A757F"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvUserStatusDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trạng thái: N/A"
                        android:textColor="#7A757F"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Actions Panel -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="6dp"
                android:text="Thao tác nhanh"
                android:textColor="#1E1A23"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1.5dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center"
                    android:weightSum="3">

                    <!-- Update -->
                    <LinearLayout
                        android:id="@+id/btnDetailEdit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_edit"
                            app:tint="#1E1A23" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Cập nhật"
                            android:textColor="#1E1A23"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Reset Pass -->
                    <LinearLayout
                        android:id="@+id/btnDetailResetPassword"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            app:tint="#1E1A23" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Mật khẩu"
                            android:textColor="#1E1A23"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Lock/Unlock -->
                    <LinearLayout
                        android:id="@+id/btnDetailLock"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">
                        <ImageView
                            android:id="@+id/ivDetailLockIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_lock_power_off"
                            app:tint="#F57C00" />
                        <TextView
                            android:id="@+id/tvDetailLockLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Khóa / Mở"
                            android:textColor="#F57C00"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="48dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
