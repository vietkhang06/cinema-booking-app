<?xml version="1.0" encoding="utf-8"?>
<!--
  Featured Movie Popup Dialog Layout
  Displayed after the customer (Guest or authenticated) enters HomeActivity.
  Theme: CINEMAX dark red-black.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:padding="24dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Centered card container for the poster -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPopup"
            android:layout_width="300dp"
            android:layout_height="450dp"
            android:clipToOutline="true"
            app:cardCornerRadius="16dp"
            app:cardElevation="16dp"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/imgFeaturedPoster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Featured movie poster" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Close (X) button - top-right corner of the poster card, overlapping -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnClosePopup"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#66000000"
            app:cardCornerRadius="18dp"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="2.5dp"
            app:cardElevation="24dp"
            app:layout_constraintTop_toTopOf="@id/cardPopup"
            app:layout_constraintEnd_toEndOf="@id/cardPopup"
            android:layout_marginTop="-18dp"
            android:layout_marginEnd="-18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
