<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="6dp"
    android:gravity="start">

    <!-- Sender Avatar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvSenderAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="2dp"
        app:cardCornerRadius="18dp"
        app:strokeWidth="0dp"
        app:cardElevation="0dp">
        <ImageView
            android:id="@+id/ivSenderAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/user_solid_full" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Content Area -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="60dp"
        android:orientation="vertical">

        <!-- Sender Label / Name -->
        <TextView
            android:id="@+id/tvSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:layout_marginStart="4dp"
            android:textColor="#757575"
            android:textSize="12sp"
            android:textStyle="bold"
            android:text="Trợ lý ảo" />

        <!-- Bubble Background -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvMessageCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#E8EAF6">
            
            <TextView
                android:id="@+id/tvMessageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:textColor="#111111"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"
                android:maxWidth="240dp"
                android:text="Nội dung tin nhắn..." />
        </com.google.android.material.card.MaterialCardView>

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:layout_marginStart="4dp"
            android:textColor="#9E9E9E"
            android:textSize="10sp"
            android:text="12:00 PM"/>

    </LinearLayout>

</LinearLayout>
