<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Ã¢â€â‚¬Ã¢â€â‚¬ HEADER Ã¢â€â‚¬Ã¢â€â‚¬ -->
    <LinearLayout
        android:id="@+id/checkoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        android:background="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnCheckoutBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/chevron_left_solid_full"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#111111" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thanh toán"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <View
        android:id="@+id/checkoutHeaderDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        app:layout_constraintTop_toBottomOf="@id/checkoutHeader" />

    <!-- Ã¢â€â‚¬Ã¢â€â‚¬ SCROLL CONTENT Ã¢â€â‚¬Ã¢â€â‚¬ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/checkoutScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/checkoutHeaderDivider"
        app:layout_constraintBottom_toTopOf="@id/checkoutBottomBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Ã¢â€â‚¬Ã¢â€â‚¬ ORDER SUMMARY Ã¢â€â‚¬Ã¢â€â‚¬ -->
            <LinearLayout
                android:id="@+id/layoutOrderSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="#F2F2F7" />

            <!-- Ã¢â€â‚¬Ã¢â€â‚¬ PAYMENT METHODS Ã¢â€â‚¬Ã¢â€â‚¬ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phương thức thanh toán"
                    android:textColor="#111111"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />

                <!-- Chuyen khoan ngan hang -->
                <LinearLayout
                    android:id="@+id/paymentBank"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp"
                    android:background="?attr/selectableItemBackground">

                    <View
                        android:id="@+id/radioBank"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_radio_unselected_cine" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="12dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#1976D2">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="B"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Chuy&#7875;n kho&#7843;n ng&#226;n h&#224;ng"
                        android:textColor="#222222"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <!-- Vi thanh toan MoMo -->
                <LinearLayout
                    android:id="@+id/paymentMomo"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp"
                    android:background="?attr/selectableItemBackground">

                    <View
                        android:id="@+id/radioMomo"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_radio_unselected_cine" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="12dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#A3166C">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="M"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="V&#237; thanh to&#225;n MoMo"
                        android:textColor="#222222"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif" />
                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="#F2F2F7" />

            <!-- ── KHUYẾN MÃI ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Khuyến mãi"
                    android:textColor="#111111"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />

                <!-- Mã voucher row header -->
                <LinearLayout
                    android:id="@+id/rowVoucherHeader"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_promo_header"
                    android:paddingHorizontal="10dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Mã voucher"
                        android:textColor="#E8640C"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnSelectPersonalVoucher"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:text="Chọn voucher"
                        android:textColor="#005FE0"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:padding="4dp"
                        android:background="?attr/selectableItemBackground" />

                    <TextView
                        android:id="@+id/tvVoucherToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▲"
                        android:textColor="#E8640C"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Voucher input row -->
                <LinearLayout
                    android:id="@+id/layoutVoucherInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/etVoucherCode"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_input_orange"
                        android:paddingHorizontal="12dp"
                        android:hint="Nhập mã voucher"
                        android:textColorHint="#BBBBBB"
                        android:textColor="#111111"
                        android:textSize="14sp"
                        android:inputType="text"
                        android:singleLine="true"
                        android:imeOptions="actionDone" />

                    <TextView
                        android:id="@+id/btnApplyVoucher"
                        android:layout_width="90dp"
                        android:layout_height="44dp"
                        android:gravity="center"
                        android:background="@drawable/bg_btn_orange_filled"
                        android:text="Áp dụng"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAppliedPromo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    android:visibility="gone"
                    android:text="Đã áp dụng: ..." />

                <!-- Điểm Star row header -->
                <LinearLayout
                    android:id="@+id/rowStarHeader"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_promo_header"
                    android:paddingHorizontal="10dp"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Sử dụng điểm Star"
                        android:textColor="#E8640C"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStarToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▲"
                        android:textColor="#E8640C"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Star input -->
                <LinearLayout
                    android:id="@+id/layoutStarInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Điểm hiện có: 0"
                        android:textColor="#888888"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etStarPoints"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_input_orange"
                            android:paddingHorizontal="12dp"
                            android:hint="Nhập số Stars"
                            android:textColorHint="#BBBBBB"
                            android:textColor="#111111"
                            android:textSize="14sp"
                            android:inputType="number"
                            android:singleLine="true"
                            android:imeOptions="actionDone" />

                        <TextView
                            android:id="@+id/btnApplyStar"
                            android:layout_width="90dp"
                            android:layout_height="44dp"
                            android:gravity="center"
                            android:background="@drawable/bg_btn_orange_filled"
                            android:text="Áp dụng"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

<LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nơi nhận hàng"
                    android:textColor="#111111"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />

                <!-- Province Spinner -->
                <Spinner
                    android:id="@+id/spinnerProvince"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_dropdown_cine"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="10dp" />

                <!-- Cinema Spinner -->
                <Spinner
                    android:id="@+id/spinnerCinema"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_dropdown_cine"
                    android:paddingHorizontal="12dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Ã¢â€â‚¬Ã¢â€â‚¬ BOTTOM BAR Ã¢â€â‚¬Ã¢â€â‚¬ -->
    <View
        android:id="@+id/checkoutDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        app:layout_constraintBottom_toTopOf="@id/checkoutBottomBar" />

    <LinearLayout
        android:id="@+id/checkoutBottomBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng cộng: "
                android:textColor="#888888"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvCheckoutTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0đ"
                android:textColor="#E8640C"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnCheckoutPay"
            android:layout_width="130dp"
            android:layout_height="46dp"
            android:gravity="center"
            android:background="@drawable/bg_btn_orange_filled"
            android:text="Thanh toán"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
