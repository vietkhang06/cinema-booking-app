<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="20dp"
    app:behavior_peekHeight="500dp">

    <!-- BottomSheet Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#E0E0E0"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chi tiết Giao dịch &amp; Đặt vé"
        android:textColor="#1E1A23"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Content Scroller -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Highlight Amount Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FFCDD2"
                app:cardBackgroundColor="#FFEBEE"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SỐ TIỀN CẦN ĐỐI SOÁT"
                        android:textColor="#C62828"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvDetailAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="120.000 đ"
                        android:textColor="#D32F2F"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvDetailMethod"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chuyển khoản Ngân hàng (MBBank)"
                        android:textColor="#7A757F"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Grid Details -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Booking Code -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Mã thanh toán"
                        android:textColor="#7A757F"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvDetailPaymentCode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="BK8F923D"
                        android:textColor="#1E1A23"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Customer ID -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Mã khách hàng"
                        android:textColor="#7A757F"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvDetailCustomerId"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="usr_12345"
                        android:textColor="#1E1A23"
                        android:textSize="13sp"
                        android:gravity="end" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#ECE8F0"
                    android:layout_marginVertical="8dp" />

                <!-- Movie Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Phim"
                        android:textColor="#7A757F"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvDetailMovie"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Lật Mặt 7: Một Điều Ước"
                        android:textColor="#1E1A23"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Cinema / Room -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Rạp / Phòng"
                        android:textColor="#7A757F"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvDetailCinema"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="CGV Vincom - Room 3"
                        android:textColor="#1E1A23"
                        android:textSize="13sp"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Show Time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Thời gian chiếu"
                        android:textColor="#7A757F"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvDetailShowtime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="20:30 - Thứ Sáu, 22/05/2026"
                        android:textColor="#1E1A23"
                        android:textSize="13sp"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Seats -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:text="Ghế đặt"
                        android:textColor="#7A757F"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvDetailSeats"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="H5, H6"
                        android:textColor="#E53935"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="end" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Action Buttons Horizontal Grid -->
    <LinearLayout
        android:id="@+id/layoutActionButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:weightSum="2">

        <!-- Reject Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRejectPayment"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="0.8"
            android:layout_marginEnd="8dp"
            android:text="Từ chối"
            android:textColor="#C62828"
            android:textStyle="bold"
            app:backgroundTint="#FFEBEE"
            app:strokeColor="#FFCDD2"
            app:strokeWidth="1dp"
            app:cornerRadius="16dp"
            tools:ignore="ButtonStyle" />

        <!-- Approve Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApprovePayment"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1.2"
            android:layout_marginStart="8dp"
            android:text="Duyệt thanh toán"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#2E7D32"
            app:cornerRadius="16dp"
            tools:ignore="ButtonStyle" />
    </LinearLayout>

</LinearLayout>
