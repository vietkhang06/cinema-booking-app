<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFC"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".ui.staff.StaffCheckSeat">

    <!-- Elegant Toolbar with Back Card & Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/staff_invoice_back_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeColor="#ECE8F0"
            app:strokeWidth="1.5dp"
            app:cardElevation="1dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/chevron_left_solid_full"
                app:tint="#1E1A23" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Sơ đồ ghế ngồi"
            android:textColor="#1E1A23"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Map Info Header -->
    <LinearLayout
        android:id="@+id/screenIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp">

        <View
            android:layout_width="200dp"
            android:layout_height="6dp"
            android:background="#CCCCCC" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MÀN HÌNH"
            android:textSize="12sp"
            android:textColor="#7A757F"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Grid of Seats -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSeatMap"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:layout_marginBottom="16dp"/>

    <!-- Legend -->
    <LinearLayout
        android:id="@+id/legendLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <!-- Available Regular -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="8dp">
            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/couch_solid_normal" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thường"
                android:textSize="10sp"
                android:textColor="#7A757F" />
        </LinearLayout>

        <!-- VIP -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="8dp">
            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/couch_solid_vip" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VIP"
                android:textSize="10sp"
                android:textColor="#7A757F" />
        </LinearLayout>

        <!-- Held -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="8dp">
            <View
                android:id="@+id/view_legend_held"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/couch_solid_selection"
                android:backgroundTint="#FF9800" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang giữ"
                android:textSize="10sp"
                android:textColor="#7A757F" />
        </LinearLayout>

        <!-- Booked -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="8dp">
            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/couch_solid_full" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã mua"
                android:textSize="10sp"
                android:textColor="#7A757F" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>