<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutCardBackground"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <!-- Card Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THẺ THÀNH VIÊN"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CINEMAX PREMIUM"
                android:textColor="#B0C4DE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"
                android:letterSpacing="0.1" />

            <!-- QR Container -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1dp">

                <ImageView
                    android:id="@+id/ivQrCode"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:padding="12dp"
                    android:src="@drawable/ic_scan_qr" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Name -->
            <TextView
                android:id="@+id/tvMemberName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="NGUYỄN VĂN A"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center" />

            <!-- Level Badge -->
            <TextView
                android:id="@+id/tvMemberLevelBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#FFF8E7"
                android:paddingHorizontal="16dp"
                android:paddingVertical="4dp"
                android:text="GOLD MEMBER"
                android:textColor="#B8860B"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Member ID / Info -->
            <TextView
                android:id="@+id/tvMemberId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="ID: 12345678"
                android:textColor="#E0E0E0"
                android:textSize="11sp"
                android:gravity="center" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Close Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Đóng"
        android:textAllCaps="false"
        android:textColor="#555555"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="20dp"
        app:strokeColor="#DDDDDD"
        app:strokeWidth="1dp" />

</LinearLayout>
