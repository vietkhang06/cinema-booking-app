<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeColor="#ECE8F0"
    app:strokeWidth="1.2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="120dp"
        android:orientation="horizontal">

        <!-- Left Accent Column: Gift Icon / Value Badge -->
        <LinearLayout
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:background="#1A3A8C"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/ivPromoIcon"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/gift_solid_full"
                app:tint="#FFD700" />

            <TextView
                android:id="@+id/tvPromoBadgeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="ƯU ĐÃI"
                android:textColor="#FFD700"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Vertical dashed-like line divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#E2E2E2" />

        <!-- Right Content Details -->
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tvPromoTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_toStartOf="@+id/btnCopyCode"
                android:text="Giảm 10% vé xem phim"
                android:textColor="#1E1A23"
                android:textSize="14sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

            <!-- Code Badge -->
            <TextView
                android:id="@+id/tvPromoCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvPromoTitle"
                android:layout_marginTop="4dp"
                android:background="#F0F4FF"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="WELCOME10"
                android:textColor="#1A3A8C"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Description -->
            <TextView
                android:id="@+id/tvPromoDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvPromoCode"
                android:layout_marginTop="6dp"
                android:text="Áp dụng cho mọi khách hàng đặt vé xem phim lần đầu tiên trên ứng dụng."
                android:textColor="#7A757F"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Footer: Expiry & Target Role Badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_below="@id/tvPromoDesc"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:tint="#7A757F" />

                <TextView
                    android:id="@+id/tvPromoValidity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="HSD: 30/06/2026"
                    android:textColor="#7A757F"
                    android:textSize="11sp" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <!-- Target Level Badge -->
                <TextView
                    android:id="@+id/tvPromoTargetRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#FFF3CD"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="VIP"
                    android:textColor="#856404"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Copy Code Card Button -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnCopyCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="#F8F9FA"
                app:strokeColor="#CED4DA"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/clipboard_solid_full"
                        app:tint="#495057" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Sao chép"
                        android:textColor="#495057"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </RelativeLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
