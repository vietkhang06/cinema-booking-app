<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#ECE8F0"
    app:strokeWidth="1.5dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Avatar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#F6F4F8">
            <ImageView
                android:id="@+id/ivStaffAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_solid_full"
                app:tint="#7A757F" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Information -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStaffName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nguyễn Văn A"
                android:textColor="#1E1A23"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStaffEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="email@cinema.com"
                android:textColor="#7A757F"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvStaffCinema"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Chi nhánh: CGV Hùng Vương"
                android:textColor="#7952B3"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Status & Action Indicator -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvStaffStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOẠT ĐỘNG"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#10B981"
                android:background="@drawable/bg_status_active_pill"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="8dp"
                android:src="@drawable/chevron_left_solid_full"
                android:rotation="180"
                app:tint="#ECE8F0" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
