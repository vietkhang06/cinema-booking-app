<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFC"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Elegant Toolbar with Back Card & Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnAdminBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeColor="#ECE8F0"
            app:strokeWidth="1.5dp"
            app:cardElevation="1dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/chevron_left_solid_full"
                app:tint="#1E1A23" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Chi tiết nhân viên"
            android:textColor="#1E1A23"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Profile Overview Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1.5dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardCornerRadius="32dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#F6F4F8">
                        <ImageView
                            android:id="@+id/ivDetailAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/user_solid_full"
                            app:tint="#7A757F" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDetailName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tên Nhân Viên"
                            android:textColor="#1E1A23"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDetailEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="email@cinema.com"
                            android:textColor="#7A757F"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvDetailPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="SĐT: 0123456789"
                            android:textColor="#7A757F"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvDetailCinema"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="CGV Hùng Vương"
                            android:textColor="#7952B3"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDetailStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOẠT ĐỘNG"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#10B981"
                        android:background="@drawable/bg_status_active_pill"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:layout_gravity="top" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Statistics Grid (2x2) -->
            <GridLayout
                android:id="@+id/gridLayoutStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginBottom="12dp">

                <!-- Stats 1: Đi trễ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeColor="#ECE8F0"
                    app:strokeWidth="1.5dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvStatLate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#E53935"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Ca đi trễ"
                            android:textColor="#7A757F"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Stats 2: Vi phạm -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeColor="#ECE8F0"
                    app:strokeWidth="1.5dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvStatViolations"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#F57C00"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Tổng vi phạm"
                            android:textColor="#7A757F"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Stats 3: Đúng giờ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeColor="#ECE8F0"
                    app:strokeWidth="1.5dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvStatOnTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#10B981"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Đúng giờ"
                            android:textColor="#7A757F"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Stats 4: Tổng phạt -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeColor="#ECE8F0"
                    app:strokeWidth="1.5dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvStatPenalty"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0đ"
                            android:textColor="#C62828"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Mức phạt phạt"
                            android:textColor="#7A757F"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Admin Details CardView (Visible only for Admin profiles) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAdminDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1.5dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin quản trị viên"
                        android:textColor="#1E1A23"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvAdminEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email: N/A"
                        android:textColor="#7A757F"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvAdminCreatedDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngày tạo tài khoản: N/A"
                        android:textColor="#7A757F"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvAdminLoginCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số lần đăng nhập: 0"
                        android:textColor="#7A757F"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvAdminStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trạng thái: N/A"
                        android:textColor="#7A757F"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Actions Panel -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="6dp"
                android:text="Thao tác nhanh"
                android:textColor="#1E1A23"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvViolationWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"
                android:text="Không thể tạo vi phạm cho chính tài khoản quản trị."
                android:textColor="#D32F2F"
                android:textSize="12sp"
                android:textStyle="italic"
                android:visibility="gone" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1.5dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center"
                    android:weightSum="4">

                    <!-- Update -->
                    <LinearLayout
                        android:id="@+id/btnDetailEdit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_edit"
                            app:tint="#1E1A23" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Cập nhật"
                            android:textColor="#1E1A23"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Reset Pass -->
                    <LinearLayout
                        android:id="@+id/btnDetailResetPassword"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            app:tint="#1E1A23" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Mật khẩu"
                            android:textColor="#1E1A23"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Log Violation -->
                    <LinearLayout
                        android:id="@+id/btnDetailAddViolation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_delete"
                            app:tint="#D32F2F" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Báo vi phạm"
                            android:textColor="#D32F2F"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Lock/Unlock -->
                    <LinearLayout
                        android:id="@+id/btnDetailLock"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">
                        <ImageView
                            android:id="@+id/ivDetailLockIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_lock_power_off"
                            app:tint="#F57C00" />
                        <TextView
                            android:id="@+id/tvDetailLockLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Khóa / Mở"
                            android:textColor="#F57C00"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Segmented Logs View -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleLogsGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:checkedButton="@id/btnTabAttendance"
                app:singleSelection="true">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTabAttendance"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lịch sử điểm danh"
                    android:textSize="13sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTabViolations"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nhật ký vi phạm"
                    android:textSize="13sp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- List Containers -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Attendance Recycler -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDetailAttendance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="visible"
                    android:nestedScrollingEnabled="false" />

                <!-- Violations Recycler -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDetailViolations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:nestedScrollingEnabled="false" />

                <!-- Empty State -->
                <TextView
                    android:id="@+id/tvLogsEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="24dp"
                    android:text="Chưa có dữ liệu"
                    android:textColor="#7A757F"
                    android:layout_gravity="center"
                    android:visibility="gone" />
            </FrameLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="48dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
