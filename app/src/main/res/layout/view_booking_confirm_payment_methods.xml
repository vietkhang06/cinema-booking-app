<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#DB9E9E"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <RadioGroup
        android:id="@+id/rgPayment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Tiền mặt -->
        <RadioButton
            android:id="@+id/rbPayCash"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Tiền mặt tại quầy"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:buttonTint="#E53935"
            android:checked="true"
            android:paddingStart="12dp"
            android:textStyle="bold"/>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A4A" android:layout_marginHorizontal="8dp"/>

        <!-- MBBank -->
        <RadioButton
            android:id="@+id/rbPayBank"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Chuyển khoản MBBank"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:buttonTint="#E53935"
            android:paddingStart="12dp"
            android:textStyle="bold"/>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A4A" android:layout_marginHorizontal="8dp"/>

        <!-- MoMo -->
        <RadioButton
            android:id="@+id/rbPayMomo"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Ví điện tử MoMo"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:buttonTint="#E53935"
            android:paddingStart="12dp"
            android:textStyle="bold"/>

    </RadioGroup>
</androidx.cardview.widget.CardView>
