<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1E1B2E"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- MoMo Logo -->
    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@android:drawable/ic_dialog_info"
        android:background="#A50064"
        android:padding="8dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="MoMo Logo"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thanh toán qua Ví MoMo"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvMomoAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Số tiền: 0 đ"
        android:textColor="#A50064"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Spinner -->
    <ProgressBar
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:indeterminate="true"
        android:indeterminateTint="#A50064"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đang kết nối an toàn tới hệ thống thanh toán MoMo..."
        android:textColor="#666688"
        android:textSize="12sp"
        android:layout_marginBottom="24dp"
        android:gravity="center"/>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancelMomo"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Hủy giao dịch"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2A2A4A"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnConfirmMomo"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1.2"
            android:text="Xác nhận thanh toán"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#A50064"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</LinearLayout>
