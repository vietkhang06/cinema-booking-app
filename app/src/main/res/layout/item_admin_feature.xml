<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardAdminFeature"
    android:layout_width="match_parent"
    android:layout_height="160dp"
    android:layout_margin="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeColor="#ECE8F0"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:cardCornerRadius="26dp"
            app:cardBackgroundColor="#F6F4F8"
            app:strokeWidth="0dp"
            android:layout_gravity="center">

            <ImageView
                android:id="@+id/ivAdminFeatureIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="feature icon"
                app:tint="#1E1A23"
                android:src="@drawable/clapperboard_solid_full" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvAdminFeatureTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phim"
            android:textColor="#1E1A23"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="12dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvAdminFeatureSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quản lý danh sách phim"
            android:textColor="#7A757F"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="4dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>