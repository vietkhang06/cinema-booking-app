<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="88dp"
    android:background="@android:color/transparent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingStart="6dp"
    android:paddingEnd="6dp"
    android:paddingBottom="12dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavRoot"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_gravity="bottom"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:strokeColor="#12000000"
        app:strokeWidth="1dp">

        <LinearLayout
            android:id="@+id/bottomNavContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingTop="8dp"
            android:paddingEnd="6dp"
            android:paddingBottom="8dp">

            <!-- 1. Tổng quan -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/navAdminHomeCard"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginHorizontal="2dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#1E1A23"
                app:strokeWidth="0dp"
                app:rippleColor="#22000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp">

                    <ImageView
                        android:id="@+id/navAdminHomeIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/house_user_solid_full"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:id="@+id/navAdminHomeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:paddingEnd="4dp"
                        android:text="Tổng quan"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Rạp chiếu -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/navAdminCinemaCard"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="2dp"
                android:layout_weight="0.8"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:strokeColor="#D3CAD7"
                app:strokeWidth="1dp"
                app:rippleColor="#22000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp">

                    <ImageView
                        android:id="@+id/navAdminCinemaIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/glasses_solid_full"
                        app:tint="#4A4650" />

                    <TextView
                        android:id="@+id/navAdminCinemaLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:paddingEnd="4dp"
                        android:text="Rạp chiếu"
                        android:textColor="#1E1A23"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. Điện ảnh -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/navAdminMovieCard"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="2dp"
                android:layout_weight="0.8"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:strokeColor="#D3CAD7"
                app:strokeWidth="1dp"
                app:rippleColor="#22000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp">

                    <ImageView
                        android:id="@+id/navAdminMovieIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/clapperboard_solid_full"
                        app:tint="#4A4650" />

                    <TextView
                        android:id="@+id/navAdminMovieLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:paddingEnd="4dp"
                        android:text="Điện ảnh"
                        android:textColor="#1E1A23"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. Nhật ký -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/navAdminLogCard"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="2dp"
                android:layout_weight="0.8"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:strokeColor="#D3CAD7"
                app:strokeWidth="1dp"
                app:rippleColor="#22000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp">

                    <ImageView
                        android:id="@+id/navAdminLogIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/clipboard_solid_full"
                        app:tint="#4A4650" />

                    <TextView
                        android:id="@+id/navAdminLogLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:paddingEnd="4dp"
                        android:text="Nhật ký"
                        android:textColor="#1E1A23"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 5. Hồ sơ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/navAdminProfileCard"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="2dp"
                android:layout_weight="0.8"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:strokeColor="#D3CAD7"
                app:strokeWidth="1dp"
                app:rippleColor="#22000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp">

                    <ImageView
                        android:id="@+id/navAdminProfileIcon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/user_solid_full"
                        app:tint="#4A4650" />

                    <TextView
                        android:id="@+id/navAdminProfileLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:paddingEnd="4dp"
                        android:text="Hồ sơ"
                        android:textColor="#1E1A23"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
