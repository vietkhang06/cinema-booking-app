<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomNavRoot"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="28dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp">

        <!-- HOME -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/navHomeCard"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#1E1A23">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="14dp">

                <ImageView
                    android:id="@+id/navHomeIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/house_user_solid_full"
                    app:tint="#FFFFFF"/>

                <TextView
                    android:id="@+id/navHomeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trang chủ"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SHOWTIME -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/navShowtimeCard"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageView
                    android:id="@+id/navShowtimeIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/glasses_solid_full"/>

                <TextView
                    android:id="@+id/navShowtimeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lịch chiếu"
                    android:layout_marginStart="6dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CART -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/navCartCard"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageView
                    android:id="@+id/navCartIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/cart_shopping_solid_full"/>

                <TextView
                    android:id="@+id/navCartLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giỏ hàng"
                    android:layout_marginStart="6dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- MOVIE -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/navMovieCard"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageView
                    android:id="@+id/navMovieIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/clapperboard_solid_full"/>

                <TextView
                    android:id="@+id/navMovieLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phim"
                    android:layout_marginStart="6dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- PROFILE -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/navProfileCard"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageView
                    android:id="@+id/navProfileIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/user_solid_full"/>

                <TextView
                    android:id="@+id/navProfileLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tài khoản"
                    android:layout_marginStart="6dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>