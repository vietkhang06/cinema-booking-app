<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="12dp">

    <!-- Snack Image Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="60dp"
        android:layout_height="60dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeColor="#ECE8F0"
        app:strokeWidth="1dp">
        <ImageView
            android:id="@+id/ivSnackImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/gift_solid_full" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Snack Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/tvSnackName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Báº¯p Sweet"
            android:textColor="#1E1A23"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSnackDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Báº¯p rang caramel thÆ¡m ngá»t"
            android:textColor="#7A757F"
            android:textSize="11sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvSnackPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="50.000 Ä‘"
            android:textColor="#A13345"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Quantity Selector -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Minus Button Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnMinus"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#F8F9FA"
            app:strokeColor="#CED4DA"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_minus" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Quantity Text -->
        <TextView
            android:id="@+id/tvQuantity"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="0"
            android:textColor="#1E1A23"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Plus Button Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnPlus"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#F8F9FA"
            app:strokeColor="#CED4DA"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_plus" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</LinearLayout>
