<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1E1B2E"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Khuyến mãi &amp; Voucher"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/edtPromoCode"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Nhập mã (GALAXY50, WELCOME10, FREESHOP)"
            android:textColorHint="#666688"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="@android:drawable/editbox_background_normal"
            android:backgroundTint="#2A2A4A"
            android:paddingHorizontal="12dp"
            android:maxLines="1"
            android:inputType="textCapCharacters"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/btnApplyPromo"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Áp dụng"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#F57C00"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvPromoStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FF5252"
        android:textSize="12sp"
        android:layout_marginTop="8dp"
        android:visibility="gone"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mã gợi ý cho bạn:"
        android:textColor="#8888AA"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="• GALAXY50: Giảm ngay 50.000 đ cho hóa đơn đặt vé\n• WELCOME10: Giảm 10% tổng hóa đơn\n• FREESHOP: Giảm ngay 20.000 đ"
        android:textColor="#666688"
        android:textSize="12sp"
        android:lineSpacingExtra="4dp"/>
</LinearLayout>
