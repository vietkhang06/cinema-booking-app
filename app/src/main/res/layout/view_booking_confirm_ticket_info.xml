<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#F5EAEA"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THÔNG TIN VÉ"
            android:textColor="#A13345"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="16dp"/>

        <!-- Phim -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Phim"
                android:textColor="#666688" android:textSize="13sp" android:textStyle="bold"
                android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/tvAgeRatingBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="P"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@android:color/transparent"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone"/>
            <TextView android:id="@+id/tvMovieName"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="—"
                android:textColor="#A13345" android:textSize="13sp"
                android:textStyle="bold" android:gravity="end"/>
        </LinearLayout>

        <!-- Rạp -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Rạp"
                android:textColor="#666688" android:textSize="13sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvCinemaName"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="2" android:text="—"
                android:textColor="#A13345" android:textSize="13sp"
                android:gravity="end"/>
        </LinearLayout>

        <!-- Suất chiếu -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Suất chiếu"
                android:textColor="#666688" android:textSize="13sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvShowtime"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="2" android:text="—"
                android:textColor="#A13345" android:textSize="13sp"
                android:gravity="end"/>
        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A4A" android:layout_marginVertical="8dp"/>

        <!-- Ghế -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Ghế"
                android:textColor="#666688" android:textSize="13sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvSeats"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="2" android:text="—"
                android:textColor="#E53935" android:textSize="13sp"
                android:textStyle="bold" android:gravity="end"/>
        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A4A" android:layout_marginVertical="8dp"/>

        <!-- Khuyến Mãi Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            
            <TextView
                android:id="@+id/btnPromo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Khuyến Mãi  ›"
                android:textColor="#FAFAFC"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_dashed_border"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tvAppliedPromo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:gravity="end"
                android:layout_marginEnd="8dp"/>
        </LinearLayout>

        <!-- Stars Points Row -->
        <LinearLayout
            android:id="@+id/layoutStars"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:background="#DB9E9E"
            android:padding="10dp">
            
            <TextView
                android:id="@+id/tvStarsLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Áp dụng điểm Stars"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Tổng tiền -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Tổng tiền"
                android:textColor="#666688" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvOriginalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginEnd="8dp"
                android:visibility="gone"/>
            <TextView android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 đ"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
