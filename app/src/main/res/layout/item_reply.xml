<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_reply"
    android:padding="12dp"
    android:layout_marginTop="8dp">

    <ImageView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/login_icon"
        android:background="#EEEEEE"/>
    
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="8dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvReplyUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reply User"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#111111"/>
            <TextView
                android:id="@+id/tvReplyTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="1 giờ trước"
                android:textSize="11sp"
                android:textColor="#888888"/>
        </LinearLayout>
        <TextView
            android:id="@+id/tvReplyContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Reply content"
            android:textSize="13sp"
            android:textColor="#333333"/>
            
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical|end">

            <ImageView
                android:id="@+id/btnReplyLike"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_thumb_up_outline"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView
                android:id="@+id/tvReplyLikeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginStart="6dp"/>

            <ImageView
                android:id="@+id/btnReplyDislike"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_thumb_down_outline"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView
                android:id="@+id/tvReplyDislikeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
