<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_rounded_white"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tặng Voucher"
        android:textColor="#1E1A23"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvGiftVoucherSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Khách hàng: -"
        android:textColor="#7A757F"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="16dp"
        app:suffixText="%">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etVoucherDiscount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Phần trăm giảm giá (vd: 10, 15...)"
            android:inputType="numberDecimal" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="24dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etVoucherMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Lời nhắn (tùy chọn)"
            android:text="Bạn được tặng 1 voucher giảm giá đặc biệt từ Admin. Chúc bạn xem phim vui vẻ!"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="2" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnCancelVoucher"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hủy"
            android:textColor="#757575"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnSendVoucher"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tặng ngay"
            android:textColor="#FFFFFF"
            app:backgroundTint="#E53935"/>
    </LinearLayout>

</LinearLayout>
