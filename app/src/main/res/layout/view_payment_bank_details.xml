<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    android:layout_marginBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Bank Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Ngân hàng"
                android:textColor="#8888AA"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvBankName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MBBank (Ngân hàng Quân Đội)"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="14sp"
                android:gravity="end"/>
        </LinearLayout>

        <!-- Account Owner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Chủ tài khoản"
                android:textColor="#8888AA"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvAccountName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CONG TY CP CINEMA VIETNAM"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="14sp"
                android:gravity="end"/>
        </LinearLayout>

        <!-- Account Number -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Số tài khoản"
                android:textColor="#8888AA"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvAccountNumber"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="09012345678"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="14sp"
                android:gravity="end"
                android:layout_marginEnd="8dp"/>
            <ImageButton
                android:id="@+id/btnCopyAccount"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/clipboard_solid_full"
                app:tint="#A13345"
                android:contentDescription="Copy Account"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginVertical="8dp"/>

        <!-- Amount -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Số tiền"
                android:textColor="#8888AA"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 đ"
                android:textColor="#E53935"
                android:textStyle="bold"
                android:textSize="16sp"
                android:gravity="end"
                android:layout_marginEnd="8dp"/>
            <ImageButton
                android:id="@+id/btnCopyAmount"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/clipboard_solid_full"
                app:tint="#A13345"
                android:contentDescription="Copy Amount"/>
        </LinearLayout>

        <!-- Transfer Code -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Nội dung chuyển khoản"
                android:textColor="#8888AA"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvPaymentCode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textColor="#E53935"
                android:textStyle="bold"
                android:textSize="16sp"
                android:gravity="end"
                android:layout_marginEnd="8dp"/>
            <ImageButton
                android:id="@+id/btnCopyCode"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/clipboard_solid_full"
                app:tint="#A13345"
                android:contentDescription="Copy Code"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
