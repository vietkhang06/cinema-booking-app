<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFC"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".ui.staff.StaffScanQRActivity">

    <!-- Elegant Toolbar with Back Card & Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/back_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeColor="#ECE8F0"
            app:strokeWidth="1.5dp"
            app:cardElevation="1dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/chevron_left_solid_full"
                app:tint="#1E1A23" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Quét Mã Vé"
            android:textColor="#1E1A23"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp">

            <!-- QR Preview Finder Area -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/preview_area"
                android:layout_width="250dp"
                android:layout_height="250dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:strokeColor="#A13345"
                app:strokeWidth="2.5dp"
                app:cardElevation="4dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#0A000000"
                    android:padding="24dp">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_scan_qr"
                        app:tint="#A13345"
                        android:alpha="0.7" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_gravity="center_vertical"
                        android:background="#A13345" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Scan Status & Results View -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1.5dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kết quả quét gần nhất:"
                        android:textSize="13sp"
                        android:textColor="#7A757F" />

                    <TextView
                        android:id="@+id/tv_scan_result"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chưa có thông tin quét"
                        android:textColor="#1E1A23"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tv_ticket_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trạng thái vé: --"
                        android:textSize="13sp"
                        android:textColor="#7A757F"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_scan_camera"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Mở Camera Quét QR"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:backgroundTint="#A13345"
                android:textColor="@color/white"
                android:layout_marginBottom="12dp"
                app:icon="@drawable/ic_scan_qr"
                app:iconTint="@color/white"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_upload_image"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Tải ảnh lên từ thư viện"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                android:backgroundTint="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1.5dp"
                android:textColor="#1E1A23"
                app:icon="@drawable/ic_pen_note"
                app:iconTint="#1E1A23"
                app:iconGravity="textStart" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
