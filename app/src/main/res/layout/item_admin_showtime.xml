<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#ECE8F0"
    app:strokeWidth="1.5dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Showtime Info Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Movie Title -->
            <TextView
                android:id="@+id/tvMovieTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên phim"
                android:textColor="#1E1A23"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <!-- Cinema & Room -->
            <TextView
                android:id="@+id/tvCinemaRoom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rạp - Phòng"
                android:textColor="#7A757F"
                android:textSize="13sp"
                android:layout_marginBottom="4dp"/>

            <!-- Date & Time -->
            <TextView
                android:id="@+id/tvShowtimeTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thời gian: 10:00 - 12:00 (20/05/2026)"
                android:textColor="#7B39F0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <!-- Price & Format -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvFormatLang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2D | Phụ đề"
                    android:textColor="#4A4A4A"
                    android:textSize="12sp"
                    android:background="#F1F5F9"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"/>

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="85.000 đ"
                    android:textColor="#EF4444"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Actions Column -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="8dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnEdit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="#F3F0FA"
                app:strokeWidth="0dp"
                app:cardElevation="0dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="#7B39F0" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnDelete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="#FEE2E2"
                app:strokeWidth="0dp"
                app:cardElevation="0dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_delete"
                    app:tint="#EF4444" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
