<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#ECE8F0"
    app:strokeWidth="1.5dp"
    app:cardElevation="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Movie Poster Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMoviePoster"
            android:layout_width="72dp"
            android:layout_height="108dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#ECE8F0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/imgMoviePoster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/clapperboard_solid_full" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Showtime ID & Status Badge -->
        <LinearLayout
            android:id="@+id/layoutHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/cardMoviePoster"
            app:layout_constraintEnd_toStartOf="@id/layoutActions">

            <TextView
                android:id="@+id/tvShowtimeId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mã: ST-12345"
                android:textColor="#7A757F"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvShowtimeStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Đang hoạt động"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_date_selected"
                android:backgroundTint="#2E7D32"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp" />
        </LinearLayout>

        <!-- Movie Title -->
        <TextView
            android:id="@+id/tvMovieTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="12dp"
            android:text="Tên phim"
            android:textColor="#1E1A23"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/layoutHeader"
            app:layout_constraintStart_toEndOf="@id/cardMoviePoster"
            app:layout_constraintEnd_toStartOf="@id/layoutActions" />

        <!-- Cinema & Room Row -->
        <LinearLayout
            android:id="@+id/layoutCinemaRoom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/tvMovieTitle"
            app:layout_constraintStart_toEndOf="@id/cardMoviePoster"
            app:layout_constraintEnd_toStartOf="@id/layoutActions">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_location_pin"
                app:tint="#7A757F" />

            <TextView
                android:id="@+id/tvCinemaRoom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Rạp - Phòng"
                android:textColor="#7A757F"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Date & Time Row -->
        <LinearLayout
            android:id="@+id/layoutShowtimeTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/layoutCinemaRoom"
            app:layout_constraintStart_toEndOf="@id/cardMoviePoster"
            app:layout_constraintEnd_toStartOf="@id/layoutActions">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/calendar_days_solid_full"
                app:tint="#7B39F0" />

            <TextView
                android:id="@+id/tvShowtimeTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Thời gian: 10:00 - 12:00 (20/05/2026)"
                android:textColor="#7B39F0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Specs & Price Row -->
        <LinearLayout
            android:id="@+id/layoutSpecs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginStart="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/layoutShowtimeTime"
            app:layout_constraintStart_toEndOf="@id/cardMoviePoster"
            app:layout_constraintEnd_toStartOf="@id/layoutActions"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvFormatLang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2D | Phụ đề"
                android:textColor="#4A4A4A"
                android:textSize="10sp"
                android:background="#F1F5F9"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp" />

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="85.000 đ"
                android:textColor="#EF4444"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Actions Column (Edit/Delete) -->
        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnEdit"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#F3F0FA"
                app:strokeWidth="0dp"
                app:cardElevation="0dp">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="#7B39F0" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnDelete"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FEE2E2"
                app:strokeWidth="0dp"
                app:cardElevation="0dp">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_delete"
                    app:tint="#EF4444" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
