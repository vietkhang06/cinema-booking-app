<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFC">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:background="#FAFAFC">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/chevron_left_solid_full"
            app:tint="@color/black"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Thông Tin Thanh Toán"
            android:textColor="@color/black"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <View android:layout_width="44dp" android:layout_height="44dp"/>
    </LinearLayout>

    <!-- Timer/Status Banner -->
    <LinearLayout
        android:id="@+id/layoutStatusBanner"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#F57C00"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/tvStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trạng thái: Đang chờ thanh toán..."
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card Hướng dẫn chuyển khoản -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#F5EAEA"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HƯỚNG DẪN CHUYỂN KHOẢN"
                        android:textColor="#A13345"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Vui lòng thực hiện chuyển khoản theo thông tin bên dưới hoặc quét mã QR. Sau khi bạn chuyển khoản thành công, hệ thống sẽ tự động cập nhật và xuất vé."
                        android:textColor="#555577"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Thông tin tài khoản -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Bank Name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Ngân hàng"
                            android:textColor="#8888AA"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvBankName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="MBBank (Ngân hàng Quân Đội)"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:gravity="end"/>
                    </LinearLayout>

                    <!-- Account Owner -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Chủ tài khoản"
                            android:textColor="#8888AA"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvAccountName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="CONG TY CP CINEMA VIETNAM"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:gravity="end"/>
                    </LinearLayout>

                    <!-- Account Number -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Số tài khoản"
                            android:textColor="#8888AA"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvAccountNumber"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="09012345678"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:gravity="end"
                            android:layout_marginEnd="8dp"/>
                        <ImageButton
                            android:id="@+id/btnCopyAccount"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/clipboard_solid_full"
                            app:tint="#A13345"
                            android:contentDescription="Copy Account"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginVertical="8dp"/>

                    <!-- Amount -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Số tiền"
                            android:textColor="#8888AA"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvAmount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0 đ"
                            android:textColor="#E53935"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:gravity="end"
                            android:layout_marginEnd="8dp"/>
                        <ImageButton
                            android:id="@+id/btnCopyAmount"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/clipboard_solid_full"
                            app:tint="#A13345"
                            android:contentDescription="Copy Amount"/>
                    </LinearLayout>

                    <!-- Transfer Code -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Nội dung chuyển khoản"
                            android:textColor="#8888AA"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvPaymentCode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            android:textColor="#E53935"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:gravity="end"
                            android:layout_marginEnd="8dp"/>
                        <ImageButton
                            android:id="@+id/btnCopyCode"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/clipboard_solid_full"
                            app:tint="#A13345"
                            android:contentDescription="Copy Code"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card QR Code -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUÉT MÃ QR ĐỂ THANH TOÁN TỰ ĐỘNG"
                        android:textColor="#2A2A3A"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <FrameLayout
                        android:layout_width="240dp"
                        android:layout_height="240dp"
                        android:background="@drawable/bg_dashed_border"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/imgQrCode"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:contentDescription="VietQR" />

                        <ProgressBar
                            android:id="@+id/pbQrLoading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:visibility="visible"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sử dụng ứng dụng ngân hàng hoặc MoMo để quét mã"
                        android:textColor="#8888AA"
                        android:textSize="11sp"
                        android:layout_marginTop="12dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Cảnh báo quan trọng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#FFF3E0"
                android:padding="12dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/circle_info_solid_full"
                    app:tint="#F57C00"
                    android:contentDescription="Warning"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Chú ý: Hãy nhập chính xác nội dung chuyển khoản ở trên để giao dịch được duyệt tự động. Vui lòng không đóng màn hình này."
                    android:textColor="#E65100"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Button Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FAFAFC"
        android:padding="16dp"
        android:orientation="vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenApp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Mở ứng dụng thanh toán"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="#A13345"
            app:cornerRadius="26dp"/>
    </LinearLayout>

</LinearLayout>
