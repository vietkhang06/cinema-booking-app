<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFC"
    android:orientation="vertical">

    <!-- Header Toolbar -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#1E1A23" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Thêm suất chiếu mới"
                android:textColor="#1E1A23"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Movie Selection -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin phim"
                        android:textColor="#7A757F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvMovie"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn phim..."
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Cinema & Room Selection -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Địa điểm chiếu"
                        android:textColor="#7A757F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <!-- Cinema selection -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvCinema"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn rạp..."
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Room selection -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvRoom"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn phòng chiếu..."
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Date & Time Selection -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lịch chiếu"
                        android:textColor="#7A757F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <!-- Date picker input -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/tietDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn ngày chiếu..."
                            android:focusable="false"
                            android:clickable="true"
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Time picker inputs -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:hintEnabled="false">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/tietStartTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Giờ bắt đầu..."
                                android:focusable="false"
                                android:clickable="true"
                                android:inputType="none"
                                android:textColor="#1E1A23"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:hintEnabled="false">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/tietEndTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Giờ kết thúc..."
                                android:focusable="false"
                                android:clickable="true"
                                android:inputType="none"
                                android:textColor="#1E1A23"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Technical & Price Info -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin kỹ thuật &amp; Giá vé"
                        android:textColor="#7A757F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <!-- Format -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvFormat"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn định dạng (2D, 3D, IMAX...)"
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Language -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvLanguage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn ngôn ngữ (Phụ đề, Thuyết minh...)"
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Base price -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/tietBasePrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Giá vé gốc (đ)..."
                            android:inputType="number"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Save & Cancel Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancel"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Hủy bỏ"
                    android:textColor="#EF4444"
                    app:strokeColor="#FCA5A5"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="2"
                    android:layout_marginStart="12dp"
                    android:text="Lưu suất chiếu"
                    android:textStyle="bold"
                    app:backgroundTint="#FF5A5F"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
