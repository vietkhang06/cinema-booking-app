<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFC"
    android:orientation="vertical">

    <!-- Header Toolbar -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#1E1A23" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Thêm suất chiếu mới"
                android:textColor="#1E1A23"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Movie Selection -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin phim"
                        android:textColor="#7A757F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/p_actvMovie"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvMovie"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn phim..."
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Movie Details Panel (Poster & Duration) -->
                    <LinearLayout
                        android:id="@+id/layoutMovieDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"
                        android:gravity="center_vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="52dp"
                            android:layout_height="78dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#ECE8F0">

                            <ImageView
                                android:id="@+id/imgMoviePoster"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/clapperboard_solid_full"/>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tvMovieDuration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thời lượng: -- phút"
                                android:textColor="#1E1A23"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tvTimePreview"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bắt đầu: --:--\nKết thúc: --:--"
                                android:textColor="#7A757F"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp"
                                android:lineSpacingExtra="2dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Cinema & Room Selection -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Địa điểm chiếu"
                        android:textColor="#7A757F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <!-- Cinema selection -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/p_actvCinema"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvCinema"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn rạp..."
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Room selection -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/p_actvRoom"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvRoom"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn phòng chiếu..."
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Date & Time Selection -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lịch chiếu"
                        android:textColor="#7A757F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <!-- Date picker input -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/tietDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn ngày chiếu..."
                            android:focusable="false"
                            android:clickable="true"
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Time picker inputs -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:hintEnabled="false">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/tietStartTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Giờ bắt đầu..."
                                android:focusable="false"
                                android:clickable="true"
                                android:inputType="none"
                                android:textColor="#1E1A23"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:hintEnabled="false">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/tietEndTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Giờ kết thúc..."
                                android:focusable="false"
                                android:clickable="true"
                                android:inputType="none"
                                android:textColor="#1E1A23"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Technical & Price Info -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin kỹ thuật &amp; Giá vé"
                        android:textColor="#7A757F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <!-- Format -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvFormat"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn định dạng (2D, 3D, IMAX...)"
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Language -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvLanguage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn ngôn ngữ (Phụ đề, Thuyết minh...)"
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Base price -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/tietBasePrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Giá vé gốc (đ)..."
                            android:inputType="number"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Preview Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFF9F9"
                app:strokeColor="#FFC1C3"
                app:strokeWidth="1dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xem trước kết quả"
                        android:textColor="#FF5A5F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvPreviewMovie"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chưa chọn phim"
                        android:textColor="#1E1A23"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvPreviewCinemaRoom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chưa chọn rạp &amp; phòng"
                        android:textColor="#7A757F"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvPreviewTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chưa chọn thời gian"
                        android:textColor="#7B39F0"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:id="@+id/tvPreviewFormatLang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2D | Phụ đề"
                            android:textColor="#4A4A4A"
                            android:textSize="12sp"
                            android:background="#E5E7EB"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"/>

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>

                        <TextView
                            android:id="@+id/tvPreviewPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 đ"
                            android:textColor="#EF4444"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Save & Cancel Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancel"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Hủy bỏ"
                    android:textColor="#EF4444"
                    app:strokeColor="#FCA5A5"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="2"
                    android:layout_marginStart="12dp"
                    android:text="Lưu suất chiếu"
                    android:textStyle="bold"
                    app:backgroundTint="#FF5A5F"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
