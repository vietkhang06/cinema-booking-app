<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#12101A">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#12101A"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            app:tint="#FFFFFF"/>

        <TextView
            android:id="@+id/tvMovieTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Chọn ghế"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <View android:layout_width="44dp" android:layout_height="44dp"/>
    </LinearLayout>

    <!-- Thông tin suất chiếu -->
    <LinearLayout
        android:id="@+id/layoutShowtimeInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="8dp"
        android:paddingTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvShowtimeDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="28 Th4"
            android:textColor="#BBBBBB"
            android:textSize="12sp"
            android:background="#2A2A3A"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/tvSeatCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 Ghế"
            android:textColor="#BBBBBB"
            android:textSize="12sp"
            android:background="#2A2A3A"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Màn hình -->
    <TextView
        android:id="@+id/tvScreen"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:gravity="center"
        android:paddingTop="10dp"
        android:paddingBottom="15dp"
        android:text="Screen"
        android:textColor="#888888"
        android:textSize="14sp"
        android:background="@drawable/bg_screen_curve"
        app:layout_constraintTop_toBottomOf="@id/layoutShowtimeInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Legend -->
    <LinearLayout
        android:id="@+id/legendLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvScreen">

        <View android:layout_width="12dp" android:layout_height="12dp"
            android:background="@drawable/couch_solid_full"
            android:layout_marginEnd="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Thường" android:textSize="11sp" android:textColor="#AAAAAA"
            android:layout_marginEnd="12dp"/>

        <View android:layout_width="12dp" android:layout_height="12dp"
            android:background="@drawable/couch_solid_full"
            android:layout_marginEnd="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="VIP" android:textSize="11sp" android:textColor="#AAAAAA"
            android:layout_marginEnd="12dp"/>

        <View android:layout_width="12dp" android:layout_height="12dp"
            android:background="@drawable/couch_solid_full"
            android:layout_marginEnd="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Đã đặt" android:textSize="11sp" android:textColor="#AAAAAA"
            android:layout_marginEnd="12dp"/>

        <View android:layout_width="12dp" android:layout_height="12dp"
            android:background="@drawable/couch_solid_full"
            android:layout_marginEnd="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Đang chọn" android:textSize="11sp" android:textColor="#AAAAAA"/>
    </LinearLayout>

    <!-- Seat map -->
    <HorizontalScrollView
        android:id="@+id/horizontalScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/bottomLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/legendLayout">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSeatMap"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </HorizontalScrollView>

    <!-- Bottom bar -->
    <LinearLayout
        android:id="@+id/bottomLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#1E1B2E"
        android:elevation="12dp"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Ghế đã chọn hiển thị dạng chip -->
        <HorizontalScrollView
            android:id="@+id/scrollSelectedSeats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/llSelectedSeatChips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp"/>
        </HorizontalScrollView>

        <!-- Divider -->
        <View
            android:id="@+id/dividerBottom"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A4A"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <!-- Tổng tiền + nút -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tổng tiền"
                    android:textColor="#666688"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/tvTotalPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 đ"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinue"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:text="Mua vé"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                app:backgroundTint="#E53935"
                app:cornerRadius="25dp"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>