<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="#ECE8F0"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Movie Poster Container with rounded corners -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="90dp"
            android:layout_height="125dp"
            android:layout_margin="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/img_poster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/login_icon" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Ticket Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingVertical="10dp"
            android:paddingRight="12dp">

            <!-- Movie Title & Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tv_movie_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Movie Title"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1E1A23"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp"
                    android:text="PAID"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="#4CAF50"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>

            <!-- Booking ID -->
            <TextView
                android:id="@+id/tv_booking_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MÃ£ vÃ©: BK123456"
                android:textSize="12sp"
                android:textColor="#7A757F"
                android:layout_marginBottom="6dp" />

            <!-- Divider line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#ECE8F0"
                android:layout_marginBottom="6dp" />

            <!-- Cinema & Room Info -->
            <TextView
                android:id="@+id/tv_cinema_room"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cinema - Room"
                android:textSize="13sp"
                android:textColor="#1E1A23"
                android:layout_marginBottom="2dp" />

            <!-- Showtime Info -->
            <TextView
                android:id="@+id/tv_showtime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Showtime Date &amp; Time"
                android:textSize="12sp"
                android:textColor="#7A757F"
                android:layout_marginBottom="2dp" />

            <!-- Seats Info -->
            <TextView
                android:id="@+id/tv_seats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gháº¿: A1, A2"
                android:textSize="13sp"
                android:textColor="#1E1A23"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_total_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="right"
                android:text="180.000 vnd"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#A13345" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
