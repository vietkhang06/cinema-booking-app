<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFC"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Elegant Toolbar with Back Card & Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnAdminBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeColor="#ECE8F0"
            app:strokeWidth="1.5dp"
            app:cardElevation="1dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/chevron_left_solid_full"
                app:tint="#1E1A23" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvFormTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Thêm nhân viên mới"
            android:textColor="#1E1A23"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Họ tên -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStaffName"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Họ và tên"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="#1E1A23"
                app:hintTextColor="#1E1A23">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtStaffName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="#1E1A23" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStaffEmail"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Địa chỉ Email"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="#1E1A23"
                app:hintTextColor="#1E1A23">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtStaffEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="#1E1A23" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Số điện thoại -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStaffPhone"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Số điện thoại"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="#1E1A23"
                app:hintTextColor="#1E1A23">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtStaffPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textColor="#1E1A23" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Mật khẩu khởi tạo (Only Create Mode) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStaffPassword"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Mật khẩu khởi tạo"
                app:passwordToggleEnabled="true"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="#1E1A23"
                app:hintTextColor="#1E1A23">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtStaffPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="#1E1A23" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Vai trò Spinner -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="6dp"
                android:text="Vai trò thành viên"
                android:textColor="#7A757F"
                android:textSize="13sp"
                android:textStyle="bold" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1.5dp">
                <Spinner
                    android:id="@+id/spinnerStaffRole"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="8dp"
                    android:background="@null" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Chi nhánh / Cinema -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="6dp"
                android:text="Chi nhánh phân công"
                android:textColor="#7A757F"
                android:textSize="13sp"
                android:textStyle="bold" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1.5dp">
                <Spinner
                    android:id="@+id/spinnerStaffCinema"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="8dp"
                    android:background="@null" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Trạng thái active/inactive -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="6dp"
                android:text="Trạng thái tài khoản"
                android:textColor="#7A757F"
                android:textSize="13sp"
                android:textStyle="bold" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1.5dp">
                <Spinner
                    android:id="@+id/spinnerStaffStatus"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="8dp"
                    android:background="@null" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Ghi chú nội bộ -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStaffNotes"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:hint="Ghi chú nội bộ (nếu có)"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="#1E1A23"
                app:hintTextColor="#1E1A23">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtStaffNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:gravity="top"
                    android:textColor="#1E1A23" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Save Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveStaff"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="8dp"
        app:backgroundTint="#1E1A23"
        app:cornerRadius="16dp"
        android:text="LƯU THÔNG TIN"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="15sp" />

</LinearLayout>
