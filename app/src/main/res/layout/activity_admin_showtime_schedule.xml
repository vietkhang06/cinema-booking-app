<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFC"
    android:orientation="vertical">

    <!-- Header Toolbar -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                app:tint="#1E1A23" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Lên lịch suất chiếu tự động"
                android:textColor="#1E1A23"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Phim, Rạp, Phòng -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cơ sở chiếu &amp; Phim"
                        android:textColor="#7A757F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <!-- Movie dropdown -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvMovie"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn phim..."
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Cinema dropdown -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvCinema"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn rạp..."
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Room dropdown -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvRoom"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn phòng chiếu..."
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Khoảng thời gian (Ngày Bắt Đầu & Kết Thúc) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thời gian áp dụng"
                        android:textColor="#7A757F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/tietStartDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Từ ngày (Ngày bắt đầu)..."
                            android:focusable="false"
                            android:clickable="true"
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEndDate"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/tietEndDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Đến ngày (Ngày kết thúc)..."
                            android:focusable="false"
                            android:clickable="true"
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Single Time Input (Only visible when 'Only once' is selected) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilSingleTime"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/tietSingleTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn giờ chiếu..."
                            android:focusable="false"
                            android:clickable="true"
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tần suất lập lịch -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tần suất lập lịch"
                        android:textColor="#7A757F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <!-- Option 0: Chỉ một lần -->
                    <LinearLayout
                        android:id="@+id/layoutFreqOnce"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">

                        <RadioButton
                            android:id="@+id/rbFreqOnce"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:checked="true"
                            app:buttonTint="#7B39F0"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chỉ một lần"
                                android:textColor="#1E1A23"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tạo đúng 1 suất chiếu duy nhất"
                                android:textColor="#7A757F"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Option 1: Hàng ngày -->
                    <LinearLayout
                        android:id="@+id/layoutFreqDaily"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">

                        <RadioButton
                            android:id="@+id/rbFreqDaily"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            app:buttonTint="#7B39F0"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hàng ngày"
                                android:textColor="#1E1A23"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tạo suất chiếu mỗi ngày (Mon - Sun)"
                                android:textColor="#7A757F"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Option 2: Thứ 2 - Thứ 6 -->
                    <LinearLayout
                        android:id="@+id/layoutFreqWeekdays"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">

                        <RadioButton
                            android:id="@+id/rbFreqWeekdays"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            app:buttonTint="#7B39F0"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thứ 2 - Thứ 6"
                                android:textColor="#1E1A23"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tạo suất chiếu từ thứ 2 tới thứ 6"
                                android:textColor="#7A757F"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Option 3: Cuối tuần -->
                    <LinearLayout
                        android:id="@+id/layoutFreqWeekends"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">

                        <RadioButton
                            android:id="@+id/rbFreqWeekends"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            app:buttonTint="#7B39F0"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cuối tuần"
                                android:textColor="#1E1A23"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tạo suất chiếu thứ 7 và chủ nhật"
                                android:textColor="#7A757F"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Option 4: Tùy chỉnh -->
                    <LinearLayout
                        android:id="@+id/layoutFreqCustom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground">

                        <RadioButton
                            android:id="@+id/rbFreqCustom"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            app:buttonTint="#7B39F0"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tùy chỉnh"
                                android:textColor="#1E1A23"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lựa chọn các thứ mong muốn"
                                android:textColor="#7A757F"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Custom Days Chooser Grid (Only visible when Custom is selected) -->
                    <GridLayout
                        android:id="@+id/layoutCustomDays"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:columnCount="4"
                        android:visibility="gone">

                        <CheckBox
                            android:id="@+id/cbMon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="T2"
                            android:textColor="#1E1A23" />

                        <CheckBox
                            android:id="@+id/cbTue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="T3"
                            android:textColor="#1E1A23" />

                        <CheckBox
                            android:id="@+id/cbWed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="T4"
                            android:textColor="#1E1A23" />

                        <CheckBox
                            android:id="@+id/cbThu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="T5"
                            android:textColor="#1E1A23" />

                        <CheckBox
                            android:id="@+id/cbFri"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="T6"
                            android:textColor="#1E1A23" />

                        <CheckBox
                            android:id="@+id/cbSat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="T7"
                            android:textColor="#1E1A23" />

                        <CheckBox
                            android:id="@+id/cbSun"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CN"
                            android:textColor="#1E1A23" />
                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Khung giờ phát sóng (Time slots selection) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTimeSlots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Khung giờ chiếu"
                        android:textColor="#7A757F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="3"
                        android:rowCount="2"
                        android:alignmentMode="alignMargins"
                        android:columnOrderPreserved="false">

                        <CheckBox
                            android:id="@+id/cbSlot09"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="09:00"
                            android:textColor="#1E1A23" />

                        <CheckBox
                            android:id="@+id/cbSlot13"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="13:00"
                            android:textColor="#1E1A23" />

                        <CheckBox
                            android:id="@+id/cbSlot16"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="16:00"
                            android:textColor="#1E1A23" />

                        <CheckBox
                            android:id="@+id/cbSlot19"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="19:00"
                            android:textColor="#1E1A23" />

                        <CheckBox
                            android:id="@+id/cbSlot22"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="22:00"
                            android:textColor="#1E1A23" />
                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Cấu hình Định dạng, Ngôn ngữ, Giá vé -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#ECE8F0"
                app:strokeWidth="1dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông số kỹ thuật &amp; Giá vé"
                        android:textColor="#7A757F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <!-- Format -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvFormat"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn định dạng (2D, 3D...)"
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Language -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actvLanguage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Chọn ngôn ngữ..."
                            android:inputType="none"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Base price -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/tietBasePrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Giá vé gốc (đ)..."
                            android:inputType="number"
                            android:textColor="#1E1A23"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Preview Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFF9F9"
                app:strokeColor="#FFC1C3"
                app:strokeWidth="1dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xem trước lịch trình"
                        android:textColor="#FF5A5F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvPreviewTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dự kiến tạo: 0 suất chiếu"
                        android:textColor="#1E1A23"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvPreviewDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vui lòng chọn đầy đủ ngày chiếu và khung giờ để tính toán."
                        android:textColor="#7A757F"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Save & Cancel Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancel"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Hủy bỏ"
                    android:textColor="#EF4444"
                    app:strokeColor="#FCA5A5"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="2"
                    android:layout_marginStart="12dp"
                    android:text="Xác nhận Lên lịch"
                    android:textStyle="bold"
                    app:backgroundTint="#FF5A5F"
                    app:cornerRadius="8dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
