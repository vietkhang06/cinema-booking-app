        <activity
            android:name=".ui.admin.showtime.AdminShowtimeListActivity"
            android:exported="false" />
        <activity
            android:name=".ui.admin.user.AdminUserManagementActivity"
            android:exported="false" />
        <activity
            android:name=".ui.admin.report.AdminReportActivity"
            android:exported="false" />

